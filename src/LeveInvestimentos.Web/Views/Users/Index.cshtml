@model IReadOnlyCollection<UserListItemViewModel>

@{
    ViewData["Title"] = "Usuários";
}

<section class="uk-section uk-section-small">
    <div class="uk-flex uk-flex-between uk-flex-middle uk-margin">
        <h1 class="uk-heading-small uk-margin-remove">Usuários</h1>
        <a asp-action="Criar" class="uk-button uk-button-primary">Cadastrar usuário</a>
    </div>

    <div asp-validation-summary="ModelOnly" class="uk-alert-danger" uk-alert></div>

    @if (Model.Count == 0)
    {
        <div class="uk-alert-primary" uk-alert>
            <p>Nenhum usuário encontrado.</p>
        </div>
    }
    else
    {
        <div class="uk-overflow-auto">
            <table class="uk-table uk-table-divider uk-table-hover uk-table-middle">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Perfil</th>
                        <th>Gestor</th>
                        <th>Senha</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>@user.RoleDisplayName</td>
                            <td>@(user.ManagerName ?? "-")</td>
                            <td>
                                @if (user.MustChangePassword)
                                {
                                    <span class="uk-label uk-label-warning">Troca pendente</span>
                                }
                                else
                                {
                                    <span class="uk-label uk-label-success">Atualizada</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
