@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Trocar senha";
}

<section class="uk-section uk-section-small">
    <div class="uk-container uk-container-small">
        <h1 class="uk-heading-small">Trocar senha</h1>

        <form asp-action="ChangePassword" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="uk-form-stacked">
            <div asp-validation-summary="ModelOnly" class="uk-alert-danger" uk-alert></div>

            <div class="uk-margin">
                <label asp-for="CurrentPassword" class="uk-form-label"></label>
                <div class="uk-form-controls">
                    <input asp-for="CurrentPassword" class="uk-input" autocomplete="current-password" />
                    <span asp-validation-for="CurrentPassword" class="uk-text-danger"></span>
                </div>
            </div>

            <div class="uk-margin">
                <label asp-for="NewPassword" class="uk-form-label"></label>
                <div class="uk-form-controls">
                    <input asp-for="NewPassword" class="uk-input" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="uk-text-danger"></span>
                </div>
            </div>

            <div class="uk-margin">
                <label asp-for="ConfirmPassword" class="uk-form-label"></label>
                <div class="uk-form-controls">
                    <input asp-for="ConfirmPassword" class="uk-input" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="uk-text-danger"></span>
                </div>
            </div>

            <button type="submit" class="uk-button uk-button-primary">Salvar senha</button>
        </form>
    </div>
</section>
